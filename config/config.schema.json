{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Config",
  "type": "object",
  "additionalProperties": false,
  "properties": {
    "$schema": {
      "type": "string",
      "title": "Schema"
    },
    "log_level": {
      "type": "string",
      "enum": [
        "debug",
        "info",
        "warning",
        "error"
      ],
      "default": "info",
      "title": "Log Level"
    },
    "ca": {
      "$ref": "#/$defs/CAConfig"
    },
    "rules": {
      "type": "array",
      "title": "Rules",
      "items": {
        "$ref": "#/$defs/Rule"
      }
    },
    "default_policy": {
      "type": "string",
      "enum": [
        "allow",
        "block"
      ],
      "default": "allow",
      "title": "Default Policy"
    },
    "http_port": {
      "type": "integer",
      "default": 8080,
      "title": "Http Port"
    },
    "forward_ports": {
      "type": "array",
      "title": "Forward Ports",
      "description": "TCP port forwards from doubleagent to the AI agent container. Used to expose agent services (e.g. web UI) to the host without breaking network isolation.",
      "items": {
        "$ref": "#/$defs/ForwardPortRule"
      }
    },
    "health_port": {
      "type": "integer",
      "default": 9000,
      "title": "Health Port"
    }
  },
  "$defs": {
    "ForwardPortRule": {
      "title": "ForwardPortRule",
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "listen_port": {
          "type": "integer",
          "minimum": 1,
          "maximum": 65535,
          "title": "Listen Port",
          "description": "Port that doubleagent listens on (published to the host)."
        },
        "target_host": {
          "type": "string",
          "minLength": 1,
          "title": "Target Host",
          "description": "Hostname of the AI agent container on the internal network."
        },
        "target_port": {
          "type": "integer",
          "minimum": 1,
          "maximum": 65535,
          "title": "Target Port",
          "description": "Port on the AI agent container to forward to."
        }
      },
      "required": [
        "listen_port",
        "target_host",
        "target_port"
      ]
    },
    "RequestRule": {
      "title": "RequestRule",
      "type": "object",
      "additionalProperties": false,
      "allOf": [
        {
          "if": {
            "properties": {
              "policy": {
                "const": "block"
              }
            }
          },
          "then": {
            "required": [
              "response"
            ]
          }
        },
        {
          "if": {
            "properties": {
              "policy": {
                "const": "allow"
              }
            }
          },
          "then": {
            "properties": {
              "response": {
                "type": "null"
              }
            }
          }
        }
      ],
      "properties": {
        "policy": {
          "type": "string",
          "enum": [
            "allow",
            "block"
          ],
          "title": "Policy"
        },
        "method": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Method"
        },
        "path_pattern": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Path Pattern"
        },
        "response": {
          "anyOf": [
            {
              "$ref": "#/$defs/BlockResponse"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Response"
        }
      },
      "required": [
        "policy"
      ]
    },
    "BlockResponse": {
      "title": "BlockResponse",
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "status": {
          "type": "integer",
          "minimum": 100,
          "maximum": 599,
          "title": "Status"
        },
        "body": {
          "type": "object",
          "additionalProperties": true,
          "title": "Body"
        }
      },
      "required": [
        "status",
        "body"
      ]
    },
    "CAConfig": {
      "title": "CAConfig",
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "cert_path": {
          "type": "string",
          "default": "/certs/ca.crt",
          "title": "Cert Path"
        }
      }
    },
    "Rule": {
      "title": "Rule",
      "description": "A domain rule. Use AllowBlockRule for inspected traffic with secret injection or request filtering, or BypassRule to tunnel a certificate-pinned domain without MITM.",
      "anyOf": [
        {
          "$ref": "#/$defs/AllowBlockRule"
        },
        {
          "$ref": "#/$defs/BypassRule"
        }
      ]
    },
    "AllowBlockRule": {
      "title": "AllowBlockRule",
      "description": "A normal inspected domain rule. Traffic may be allowed or blocked, secrets may be injected, and nested request rules may match method and path.",
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "domains": {
          "type": "array",
          "minItems": 1,
          "title": "Domains",
          "description": "Exact hostnames or wildcard subdomain patterns such as *.example.com.",
          "items": {
            "type": "string"
          }
        },
        "secrets": {
          "type": "array",
          "title": "Secrets",
          "description": "Secrets to inject into matching requests after TLS interception.",
          "items": {
            "$ref": "#/$defs/SecretRule"
          }
        },
        "policy": {
          "anyOf": [
            {
              "type": "string",
              "enum": [
                "allow",
                "block"
              ]
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Policy",
          "description": "Optional domain-level policy for inspected traffic. If omitted, request sub-rules still apply and unmatched traffic falls back to default_policy."
        },
        "rules": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/RequestRule"
          },
          "title": "Rules",
          "description": "Optional request-level rules that match HTTP method and path after TLS interception."
        }
      },
      "required": [
        "domains"
      ]
    },
    "BypassRule": {
      "title": "BypassRule",
      "description": "A passthrough domain rule. Traffic is tunneled without TLS interception, so secret injection and request-level rules are unavailable.",
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "domains": {
          "type": "array",
          "minItems": 1,
          "title": "Domains",
          "description": "Exact hostnames or wildcard subdomain patterns to tunnel without MITM.",
          "items": {
            "type": "string"
          }
        },
        "policy": {
          "const": "bypass",
          "title": "Policy",
          "description": "Tunnel matching TLS connections without interception."
        }
      },
      "required": [
        "domains",
        "policy"
      ]
    },
    "SecretRule": {
      "title": "SecretRule",
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "placeholder": {
          "type": "string",
          "minLength": 1,
          "title": "Placeholder"
        },
        "value": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Value"
        },
        "value_from_env": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Value From Env"
        },
        "inject_in": {
          "type": "array",
          "minItems": 1,
          "title": "Inject In",
          "items": {
            "type": "string",
            "pattern": "^(header:.+|query:.+)$"
          }
        }
      },
      "required": [
        "placeholder",
        "inject_in"
      ]
    }
  }
}
