{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Config",
  "type": "object",
  "additionalProperties": false,
  "properties": {
    "$schema": {
      "type": "string",
      "title": "Schema"
    },
    "log_level": {
      "type": "string",
      "enum": [
        "debug",
        "info",
        "warning",
        "error"
      ],
      "default": "info",
      "title": "Log Level"
    },
    "ca": {
      "$ref": "#/$defs/CAConfig"
    },
    "rules": {
      "type": "array",
      "title": "Rules",
      "items": {
        "$ref": "#/$defs/Rule"
      }
    },
    "default_policy": {
      "type": "string",
      "enum": [
        "allow",
        "block"
      ],
      "default": "allow",
      "title": "Default Policy"
    },
    "http_port": {
      "type": "integer",
      "default": 8080,
      "title": "Http Port"
    },
    "health_port": {
      "type": "integer",
      "default": 9000,
      "title": "Health Port"
    }
  },
  "$defs": {
    "AllowRule": {
      "title": "AllowRule",
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "method": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Method"
        },
        "path_pattern": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Path Pattern"
        }
      }
    },
    "BlockResponse": {
      "title": "BlockResponse",
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "status": {
          "type": "integer",
          "minimum": 100,
          "maximum": 599,
          "title": "Status"
        },
        "body": {
          "type": "object",
          "additionalProperties": true,
          "title": "Body"
        }
      },
      "required": [
        "status",
        "body"
      ]
    },
    "BlockRule": {
      "title": "BlockRule",
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "method": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Method"
        },
        "path_pattern": {
          "type": "string",
          "minLength": 1,
          "title": "Path Pattern"
        },
        "response": {
          "$ref": "#/$defs/BlockResponse"
        }
      },
      "required": [
        "path_pattern",
        "response"
      ]
    },
    "CAConfig": {
      "title": "CAConfig",
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "cert_path": {
          "type": "string",
          "default": "/certs/ca.crt",
          "title": "Cert Path"
        }
      }
    },
    "Rule": {
      "title": "Rule",
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "domains": {
          "type": "array",
          "minItems": 1,
          "title": "Domains",
          "items": {
            "type": "string"
          }
        },
        "secrets": {
          "type": "array",
          "title": "Secrets",
          "items": {
            "$ref": "#/$defs/SecretRule"
          }
        },
        "block": {
          "anyOf": [
            {
              "type": "boolean"
            },
            {
              "type": "array",
              "items": {
                "$ref": "#/$defs/BlockRule"
              }
            }
          ],
          "title": "Block"
        },
        "allow": {
          "anyOf": [
            {
              "type": "boolean"
            },
            {
              "type": "array",
              "items": {
                "$ref": "#/$defs/AllowRule"
              }
            }
          ],
          "title": "Allow"
        }
      },
      "required": [
        "domains"
      ]
    },
    "SecretRule": {
      "title": "SecretRule",
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "placeholder": {
          "type": "string",
          "minLength": 1,
          "title": "Placeholder"
        },
        "value": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Value"
        },
        "value_from_env": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Value From Env"
        },
        "inject_in": {
          "type": "array",
          "minItems": 1,
          "title": "Inject In",
          "items": {
            "type": "string",
            "pattern": "^(header:.+|query:.+)$"
          }
        }
      },
      "required": [
        "placeholder",
        "inject_in"
      ]
    }
  }
}
